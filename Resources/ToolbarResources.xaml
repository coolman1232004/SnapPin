<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- Compact defaults produce a 34 px outer toolbar at 100% scaling. -->
    <sys:Double x:Key="ToolbarButtonSize">28</sys:Double>
    <sys:Double x:Key="ToolbarIconSize">18</sys:Double>
    <sys:Double x:Key="ToolbarGripWidth">14</sys:Double>
    <sys:Double x:Key="ToolbarSeparatorHeight">18</sys:Double>
    <Thickness x:Key="ToolbarButtonPadding">4</Thickness>
    <Thickness x:Key="ToolbarButtonMargin">1,0</Thickness>
    <Thickness x:Key="ToolbarFramePadding">6,2</Thickness>
    <Thickness x:Key="ToolbarSeparatorMargin">3,5</Thickness>

    <SolidColorBrush x:Key="ToolbarSurfaceBrush" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="#FFE2E8F0"/>
    <SolidColorBrush x:Key="ToolbarInkBrush" Color="#FF334155"/>
    <SolidColorBrush x:Key="ToolbarHoverBrush" Color="#FFF1F5F9"/>
    <SolidColorBrush x:Key="ToolbarPressedBrush" Color="#FFE2E8F0"/>
    <SolidColorBrush x:Key="ToolbarActiveBrush" Color="#FFCCFBF1"/>
    <SolidColorBrush x:Key="ToolbarActiveInkBrush" Color="#FF0D9488"/>
    <SolidColorBrush x:Key="ToolbarSeparatorBrush" Color="#FFCBD5E1"/>
    <SolidColorBrush x:Key="ToolbarGripBrush" Color="#FFCBD5E1"/>

    <!-- Drawing tools. All geometries share a 24 x 24 optical canvas. -->
    <Geometry x:Key="ToolbarRectangleIcon">M4,5 H20 V19 H4 Z M6.5,16.5 H9.5 V19.5 H6.5 Z</Geometry>
    <Geometry x:Key="ToolbarEllipseIcon">M3,12 A9,7.5 0 1 0 21,12 A9,7.5 0 1 0 3,12</Geometry>
    <Geometry x:Key="ToolbarArrowIcon">M3,20 L20,3 M12.5,3 H20 V10.5</Geometry>
    <Geometry x:Key="ToolbarLineIcon">M4,20 L20,4</Geometry>
    <Geometry x:Key="ToolbarPencilIcon">M4,20 L5.5,14.5 L16.5,3.5 Q17.5,2.5 18.5,3.5 L21,6 Q22,7 21,8 L10,19 Z M5.5,14.5 L10,19</Geometry>
    <Geometry x:Key="ToolbarMarkerIcon">M5,16 L15.5,4.5 L20,9 L9.5,20.5 H4.5 Z M8.5,19.5 L12,23 M16.5,13 L20.5,17</Geometry>
    <Geometry x:Key="ToolbarBlurIcon">M12,2.5 C10.5,6.5 5.5,10.5 5.5,15 A6.5,6.5 0 1 0 18.5,15 C18.5,10.5 13.5,6.5 12,2.5 Z</Geometry>
    <!-- A plain, upright T remains legible at the compact 18 px toolbar size. -->
    <Geometry x:Key="ToolbarTextIcon">M4,4 H20 M12,4 V21</Geometry>
    <Geometry x:Key="ToolbarEraserIcon">M4,16 L14.5,4.5 Q16.5,2.5 18.5,4.5 L21,7 Q23,9 21,11 L11,21 H7 L3,19 Z M9,19 L18.5,9.5</Geometry>
    <Geometry x:Key="ToolbarMagnifyIcon">M10,3.5 A6.5,6.5 0 1 0 10,16.5 A6.5,6.5 0 1 0 10,3.5 M14.7,14.7 L21,21 M7,10 H13 M10,7 V13</Geometry>

    <!-- History and output actions. -->
    <Geometry x:Key="ToolbarUndoIcon">M10,6 L4,12 L10,18 M5,12 H14 Q21,12 21,19</Geometry>
    <Geometry x:Key="ToolbarRedoIcon">M14,6 L20,12 L14,18 M19,12 H10 Q3,12 3,19</Geometry>
    <!-- Rounded outline thumbtack, tilted to match the visual language of the reference artwork. -->
    <PathGeometry x:Key="ToolbarPinIcon"
                  Figures="M7,5 A5,2.5 0 1 1 17,5 A5,2.5 0 1 1 7,5 M9,6.5 L10,12 M15,6.5 L14,12 M10,12 C7.5,12.5 6,14 6,16 C9.8,17.4 14.2,17.4 18,16 C18,14 16.5,12.5 14,12 M12,17.2 V22">
        <PathGeometry.Transform>
            <RotateTransform Angle="32" CenterX="12" CenterY="12"/>
        </PathGeometry.Transform>
    </PathGeometry>
    <Geometry x:Key="ToolbarPinThumbnailIcon">M4,5 H18 V17 H4 Z M12,10 L20,2 M16,2 H20 V6</Geometry>
    <Geometry x:Key="ToolbarCopyIcon">M4,7 H17 V21 H4 Z M8,3 H21 V17</Geometry>
    <Geometry x:Key="ToolbarSaveIcon">M4,3 H18 L21,6 V21 H4 Z M8,3 V9 H17 V3 M8,15 H18 V21 H8 Z</Geometry>
    <Geometry x:Key="ToolbarQuickSaveIcon">M13,2 L5,13 H11 L9,22 L20,10 H14 Z</Geometry>
    <Geometry x:Key="ToolbarLongCaptureIcon">M5,3 H19 V21 H5 Z M5,7 H19 M12,10 V18 M8.5,14.5 L12,18 L15.5,14.5</Geometry>
    <Geometry x:Key="ToolbarRecordIcon">M3.5,6 H15.5 V18 H3.5 Z M15.5,10 L21,7 V17 L15.5,14 Z M8,9 A3,3 0 1 0 14,9 A3,3 0 1 0 8,9</Geometry>
    <Geometry x:Key="ToolbarOcrIcon">M4,8 V4 H8 M16,4 H20 V8 M20,16 V20 H16 M8,20 H4 V16 M8,9 H16 M8,12 H16 M8,15 H13</Geometry>
    <Geometry x:Key="ToolbarRecaptureIcon">M4,9 V4 H9 M15,4 H20 V9 M20,15 V20 H15 M9,20 H4 V15 M12,8 V16 M8,12 H16</Geometry>
    <Geometry x:Key="ToolbarApplyIcon">M3,12.5 L9,19 L21,5</Geometry>
    <Geometry x:Key="ToolbarCancelIcon">M5,5 L19,19 M19,5 L5,19</Geometry>

    <Style x:Key="ToolbarIconPathStyle" TargetType="Path">
        <Setter Property="Width" Value="{DynamicResource ToolbarIconSize}"/>
        <Setter Property="Height" Value="{DynamicResource ToolbarIconSize}"/>
        <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
        <Setter Property="StrokeThickness" Value="1.7"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="SnapAnchorToolbarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="{DynamicResource ToolbarButtonSize}"/>
        <Setter Property="Height" Value="{DynamicResource ToolbarButtonSize}"/>
        <Setter Property="Padding" Value="{DynamicResource ToolbarButtonPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource ToolbarButtonMargin}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ToolbarInkBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ToolbarButtonBackground"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          SnapsToDevicePixels="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToolbarButtonBackground" Property="Background" Value="{DynamicResource ToolbarHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ToolbarButtonBackground" Property="Background" Value="{DynamicResource ToolbarPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
