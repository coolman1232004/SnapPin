<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <sys:Double x:Key="ToolbarButtonSize">26</sys:Double>
    <sys:Double x:Key="ToolbarIconSize">18</sys:Double>
    <sys:Double x:Key="ToolbarGripWidth">14</sys:Double>
    <sys:Double x:Key="ToolbarSeparatorHeight">18</sys:Double>
    <Thickness x:Key="ToolbarButtonPadding">2</Thickness>
    <Thickness x:Key="ToolbarButtonMargin">1</Thickness>
    <Thickness x:Key="ToolbarFramePadding">3,1</Thickness>
    <Thickness x:Key="ToolbarSeparatorMargin">3,4</Thickness>
    <SolidColorBrush x:Key="ToolbarSurfaceBrush" Color="#FCF8F9FA"/>
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="#C9D0D9"/>
    <SolidColorBrush x:Key="ToolbarInkBrush" Color="#101828"/>
    <SolidColorBrush x:Key="ToolbarHoverBrush" Color="#EEF3F8"/>
    <SolidColorBrush x:Key="ToolbarPressedBrush" Color="#DCE8F5"/>
    <SolidColorBrush x:Key="ToolbarActiveBrush" Color="#C5E6F7"/>
    <SolidColorBrush x:Key="ToolbarSeparatorBrush" Color="#D1D5DB"/>

    <Geometry x:Key="ToolbarArrowIcon">M2,19 C7,17 10,12 14,9 L21,3 M14,3 L21,3 L21,10</Geometry>
    <Geometry x:Key="ToolbarLineIcon">M3,21 L22,3</Geometry>
    <Geometry x:Key="ToolbarPencilIcon">M4,20 L7,14 L18,3 L23,8 L12,19 Z M7,14 L12,19</Geometry>
    <Geometry x:Key="ToolbarMarkerIcon">M5,17 L16,4 L22,10 L11,23 L4,23 Z M14,19 L19,24</Geometry>
    <Geometry x:Key="ToolbarBlurIcon">M12,2 C10,6 5,10 5,15 A7,7 0 1 0 19,15 C19,10 14,6 12,2 Z</Geometry>
    <Geometry x:Key="ToolbarTextIcon">M3,4 H21 M12,4 V22 M7,22 H17</Geometry>
    <Geometry x:Key="ToolbarEraserIcon">M4,16 L15,4 Q17,2 19,4 L23,8 Q25,10 23,12 L13,23 L7,23 L3,19 Z M9,21 L19,11</Geometry>
    <Geometry x:Key="ToolbarMagnifyIcon">M10,3 A7,7 0 1 0 10,17 A7,7 0 1 0 10,3 M15,15 L22,22 M7,10 H13 M10,7 V13</Geometry>
    <Geometry x:Key="ToolbarUndoIcon">M10,6 L3,12 L10,18 M4,12 H14 Q22,12 22,20</Geometry>
    <Geometry x:Key="ToolbarRedoIcon">M16,6 L23,12 L16,18 M22,12 H12 Q4,12 4,20</Geometry>
    <Geometry x:Key="ToolbarCopyIcon">M4,7 H17 V21 H4 Z M8,3 H21 V17</Geometry>
    <Geometry x:Key="ToolbarSaveIcon">M4,3 H19 L23,7 V23 H4 Z M8,3 V10 H18 V3 M8,17 H19 V23 H8 Z</Geometry>
    <Geometry x:Key="ToolbarApplyIcon">M3,13 L9,20 L23,4</Geometry>
    <Geometry x:Key="ToolbarCancelIcon">M5,5 L19,19 M19,5 L5,19</Geometry>

    <Style x:Key="SnapPinToolbarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="{DynamicResource ToolbarButtonSize}"/>
        <Setter Property="Height" Value="{DynamicResource ToolbarButtonSize}"/>
        <Setter Property="Padding" Value="{DynamicResource ToolbarButtonPadding}"/>
        <Setter Property="Margin" Value="{DynamicResource ToolbarButtonMargin}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ToolbarInkBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ToolbarButtonBackground" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                        <ContentPresenter Width="{DynamicResource ToolbarIconSize}" Height="{DynamicResource ToolbarIconSize}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ToolbarButtonBackground" Property="Background" Value="{DynamicResource ToolbarHoverBrush}"/></Trigger>
                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="ToolbarButtonBackground" Property="Background" Value="{DynamicResource ToolbarPressedBrush}"/></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.28"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
