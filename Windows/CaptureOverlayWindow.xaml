<Window x:Class="SnapAnchor.Windows.CaptureOverlayWindow" Title="SnapAnchor Capture"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SnapAnchor.Controls"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True" AllowsTransparency="True"
        Cursor="Cross" Background="Black" KeyDown="Window_KeyDown" MouseWheel="Window_MouseWheel"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp" SizeChanged="Window_SizeChanged">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SnapAnchor;component/Resources/ToolbarResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="CaptureActionButton" TargetType="Button" BasedOn="{StaticResource SnapAnchorToolbarButtonStyle}"/>
            <Style x:Key="HandleStyle" TargetType="Ellipse">
                <Setter Property="Width" Value="13"/><Setter Property="Height" Value="13"/>
                <Setter Property="Fill" Value="#3388FF"/><Setter Property="Stroke" Value="White"/>
                <Setter Property="StrokeThickness" Value="2"/><Setter Property="Cursor" Value="SizeAll"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid x:Name="Root">
        <Image x:Name="ScreenImage" Stretch="Fill" SnapsToDevicePixels="True" UseLayoutRounding="True"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        <Rectangle x:Name="MaskLayer" Fill="#66000000"/>
        <Canvas x:Name="SelectionMask" Visibility="Collapsed" IsHitTestVisible="False">
            <Rectangle x:Name="MaskTop" Fill="#66000000"/><Rectangle x:Name="MaskLeft" Fill="#66000000"/>
            <Rectangle x:Name="MaskRight" Fill="#66000000"/><Rectangle x:Name="MaskBottom" Fill="#66000000"/>
        </Canvas>
        <Canvas x:Name="OverlayCanvas">
            <Rectangle x:Name="DetectionRect" Visibility="Collapsed" Stroke="#3388FF" StrokeThickness="2" StrokeDashArray="6,3" Fill="#06000000" IsHitTestVisible="False"/>
            <Line x:Name="CrossHorizontal" Visibility="Collapsed" Stroke="#883388FF" StrokeThickness="1" StrokeDashArray="6,3"/>
            <Line x:Name="CrossVertical" Visibility="Collapsed" Stroke="#883388FF" StrokeThickness="1" StrokeDashArray="6,3"/>
            <Rectangle x:Name="SelectionRect" Visibility="Collapsed" Stroke="#3388FF" StrokeThickness="2" Fill="#05FFFFFF" IsHitTestVisible="False" Panel.ZIndex="3400"/>
            <Rectangle x:Name="OcrAreaRect" Visibility="Collapsed" Stroke="#F59E0B" StrokeThickness="2" StrokeDashArray="6,3" Fill="#22F59E0B" IsHitTestVisible="False" Panel.ZIndex="2500"/>

            <Canvas x:Name="SelectionHandles" Visibility="Collapsed" Panel.ZIndex="3500">
                <Ellipse x:Name="HandleNW" Style="{StaticResource HandleStyle}" Tag="NW" Cursor="SizeNWSE" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
                <Ellipse x:Name="HandleN" Style="{StaticResource HandleStyle}" Tag="N" Cursor="SizeNS" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
                <Ellipse x:Name="HandleNE" Style="{StaticResource HandleStyle}" Tag="NE" Cursor="SizeNESW" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
                <Ellipse x:Name="HandleE" Style="{StaticResource HandleStyle}" Tag="E" Cursor="SizeWE" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
                <Ellipse x:Name="HandleSE" Style="{StaticResource HandleStyle}" Tag="SE" Cursor="SizeNWSE" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
                <Ellipse x:Name="HandleS" Style="{StaticResource HandleStyle}" Tag="S" Cursor="SizeNS" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
                <Ellipse x:Name="HandleSW" Style="{StaticResource HandleStyle}" Tag="SW" Cursor="SizeNESW" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
                <Ellipse x:Name="HandleW" Style="{StaticResource HandleStyle}" Tag="W" Cursor="SizeWE" MouseLeftButtonDown="Handle_MouseLeftButtonDown"/>
            </Canvas>

            <Border x:Name="SizeBadge" Visibility="Collapsed" Background="#E8212530" CornerRadius="14" Padding="10,5">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
            </Border>
            <Border x:Name="OcrAreaHint" Visibility="Collapsed" Background="#E8212530" CornerRadius="14" Padding="12,6" Panel.ZIndex="2600" IsHitTestVisible="False">
                <TextBlock Text="Drag the smaller area to recognize" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
            </Border>

            <Border x:Name="ActionBar" Visibility="Collapsed" Background="{DynamicResource ToolbarSurfaceBrush}" BorderBrush="{DynamicResource ToolbarBorderBrush}" BorderThickness="1" CornerRadius="7" Padding="{DynamicResource ToolbarFramePadding}" Panel.ZIndex="4000" SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Border.Effect><DropShadowEffect Color="#26000000" BlurRadius="8" ShadowDepth="2" Opacity="0.22"/></Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Grid Width="{DynamicResource ToolbarGripWidth}" Height="{DynamicResource ToolbarButtonSize}" Margin="0,0,2,0" IsHitTestVisible="False">
                        <UniformGrid Rows="3" Columns="2" Width="8" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Fill="{DynamicResource ToolbarGripBrush}" Margin="1"/><Ellipse Fill="{DynamicResource ToolbarGripBrush}" Margin="1"/><Ellipse Fill="{DynamicResource ToolbarGripBrush}" Margin="1"/><Ellipse Fill="{DynamicResource ToolbarGripBrush}" Margin="1"/><Ellipse Fill="{DynamicResource ToolbarGripBrush}" Margin="1"/><Ellipse Fill="{DynamicResource ToolbarGripBrush}" Margin="1"/>
                        </UniformGrid>
                    </Grid>
                    <WrapPanel x:Name="CaptureAnnotationToolPanel">
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Rectangle" ToolTip="Rectangle" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarRectangleIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Ellipse" ToolTip="Ellipse" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarEllipseIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Arrow" ToolTip="Arrow" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarArrowIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Line" ToolTip="Straight line" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarLineIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Pencil" ToolTip="Pencil" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarPencilIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Marker" ToolTip="Marker" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarMarkerIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Blur" ToolTip="Blur brush" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarBlurIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Text" ToolTip="Text" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarTextIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Eraser" ToolTip="Eraser" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarEraserIcon}"/></Button>
                        <Button Style="{StaticResource CaptureActionButton}" Tag="Magnify" ToolTip="Magnifier" Click="QuickAnnotation_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarMagnifyIcon}"/></Button>
                    </WrapPanel>
                    <Border Width="1" Height="{DynamicResource ToolbarSeparatorHeight}" Background="{DynamicResource ToolbarSeparatorBrush}" Margin="{DynamicResource ToolbarSeparatorMargin}"/>
                    <StackPanel x:Name="AnnotationHistoryPanel" Orientation="Horizontal">
                        <Button x:Name="CaptureUndoButton" IsEnabled="False" Style="{StaticResource CaptureActionButton}" ToolTip="Undo (Ctrl+Z)" Click="AnnotationUndo_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarUndoIcon}"/></Button>
                        <Button x:Name="CaptureRedoButton" IsEnabled="False" Style="{StaticResource CaptureActionButton}" ToolTip="Redo (Ctrl+Y)" Click="AnnotationRedo_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarRedoIcon}"/></Button>
                        <Border Width="1" Height="{DynamicResource ToolbarSeparatorHeight}" Background="{DynamicResource ToolbarSeparatorBrush}" Margin="{DynamicResource ToolbarSeparatorMargin}"/>
                    </StackPanel>
                    <StackPanel x:Name="CaptureActionPanel" Orientation="Horizontal">
                        <Button x:Name="CopyCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="Copy" ToolTip="Copy" Click="Copy_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarCopyIcon}"/></Button>
                        <Button x:Name="PinCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="Pin" ToolTip="Pin" Click="Pin_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarPinIcon}"/></Button>
                        <Button x:Name="PinThumbnailCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="PinThumbnail" ToolTip="Pin as thumbnail" Click="PinThumbnail_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarPinThumbnailIcon}"/></Button>
                        <Button x:Name="SaveCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="Save" ToolTip="Save as image" Click="Save_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarSaveIcon}"/></Button>
                        <Button x:Name="QuickSaveCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="QuickSave" ToolTip="Quick save" Click="QuickSave_Click"><Path Width="{DynamicResource ToolbarIconSize}" Height="{DynamicResource ToolbarIconSize}" Data="{StaticResource ToolbarQuickSaveIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/></Button>
                        <Button x:Name="LongCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="LongCapture" ToolTip="Long scrolling screenshot (L)" Click="LongCapture_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarLongCaptureIcon}"/></Button>
                        <Button x:Name="RecordCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="Record" ToolTip="Record selected region (R)" Click="Record_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarRecordIcon}"/></Button>
                        <Button x:Name="OcrCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="OCR" ToolTip="Recognize text and QR/barcodes" Click="Recognize_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarOcrIcon}"/></Button>
                        <Button x:Name="RecaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="Recapture" ToolTip="Capture another area" Click="Recapture_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarRecaptureIcon}"/></Button>
                        <Button x:Name="CancelCaptureActionButton" Style="{StaticResource CaptureActionButton}" Tag="Cancel" ToolTip="Cancel" Click="Cancel_Click"><Path Style="{StaticResource ToolbarIconPathStyle}" Data="{StaticResource ToolbarCancelIcon}"/></Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="RecordingBar" Visibility="Collapsed" Background="#F21D2028" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="10" Padding="10,7">
                <Border.Effect><DropShadowEffect Color="#66000000" BlurRadius="14" ShadowDepth="3"/></Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="2,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="RecordingTimerText" Text="00:00" Foreground="White" FontSize="15" FontWeight="SemiBold" MinWidth="62" VerticalAlignment="Center"/>
                    <TextBlock x:Name="RecordingFrameText" Text="0 frames" Foreground="#AAB2C0" FontSize="12" Margin="6,0,12,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="RecordingCursorBox" Content="Cursor" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="RecordingPauseButton" ToolTip="Pause recording (Space)" Width="82" Height="34" Margin="2" Background="#292524" BorderBrush="#57534E" Click="RecordingPause_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Grid Width="18" Height="18" Margin="0,0,6,0">
                                <Grid x:Name="RecordingPauseIcon"><Path Data="M2,1 H7 V17 H2 Z M11,1 H16 V17 H11 Z" Fill="White" Stretch="Fill"/></Grid>
                                <Path x:Name="RecordingResumeIcon" Data="M3,1 L16,9 L3,17 Z" Fill="White" Visibility="Collapsed" Stretch="Fill"/>
                            </Grid>
                            <TextBlock x:Name="RecordingPauseLabel" Text="Pause" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RecordingStopButton" ToolTip="Stop and review recording (R or Esc)" Width="72" Height="34" Margin="2" Background="#EF4444" BorderBrush="#F87171" Click="RecordingStop_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Viewbox Width="18" Height="18" Margin="0,0,6,0"><Path Data="M2,2 H16 V16 H2 Z" Fill="White" Stretch="Uniform"/></Viewbox>
                            <TextBlock Text="Stop" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border x:Name="RecordingCountdownBadge" Visibility="Collapsed" Background="#E61D2028" CornerRadius="40" Width="82" Height="82" IsHitTestVisible="False">
                <TextBlock x:Name="RecordingCountdownText" Text="3" Foreground="White" FontSize="38" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <Border x:Name="RecordingReviewPanel" Width="620" Height="470" MinWidth="300" MinHeight="260" Visibility="Collapsed" Background="#FAFFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="14" Padding="16">
                <Border.Effect><DropShadowEffect Color="#66000000" BlurRadius="22" ShadowDepth="5"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DockPanel x:Name="RecordingReviewHeader" Margin="0,0,0,12" Cursor="SizeAll" MouseLeftButtonDown="RecordingReviewHeader_MouseLeftButtonDown" MouseMove="RecordingReviewHeader_MouseMove" MouseLeftButtonUp="RecordingReviewHeader_MouseLeftButtonUp"><TextBlock Text="Review and trim recording" FontSize="20" FontWeight="SemiBold" Foreground="#1C1917"/><TextBlock x:Name="TrimDurationText" DockPanel.Dock="Right" Foreground="#57534E" VerticalAlignment="Center"/></DockPanel>
                    <Border Grid.Row="1" Background="#101216" CornerRadius="8" ClipToBounds="True">
                        <MediaElement x:Name="RecordingPreviewMedia" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" MediaEnded="RecordingPreviewMedia_MediaEnded"/>
                    </Border>
                    <Grid Grid.Row="2" Margin="0,12,0,8">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="62"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Start" Foreground="#57534E" VerticalAlignment="Center"/><Slider x:Name="TrimStartSlider" Grid.Column="1" Minimum="0" ValueChanged="TrimSlider_Changed"/><TextBlock x:Name="TrimStartText" Grid.Column="2" Foreground="#57534E" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Row="1" Text="End" Foreground="#57534E" VerticalAlignment="Center"/><Slider x:Name="TrimEndSlider" Grid.Row="1" Grid.Column="1" Minimum="0" ValueChanged="TrimSlider_Changed"/><TextBlock x:Name="TrimEndText" Grid.Row="1" Grid.Column="2" Foreground="#57534E" HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock x:Name="RecordingSavePathText" Grid.Row="3" Foreground="#57534E" FontSize="12" Margin="0,0,0,9" TextTrimming="CharacterEllipsis"/>
                    <DockPanel Grid.Row="4">
                        <Button Content="Keep full" DockPanel.Dock="Right" Width="96" Height="38" Margin="8,0,0,0" Background="#D0D5DD" Click="KeepFullRecording_Click"/>
                        <Button Content="Save trimmed" DockPanel.Dock="Right" Width="112" Height="38" Margin="8,0,0,0" Background="#292524" Foreground="White" Click="SaveTrimmedRecording_Click"/>
                        <Button x:Name="DiscardRecordingButton" Content="Discard" DockPanel.Dock="Right" Width="82" Height="38" Margin="8,0,0,0" Background="#FEE2E2" Foreground="#B42318" BorderBrush="#FDA29B" Click="DiscardRecording_Click"/>
                        <Button x:Name="RecordingPreviewPlayButton" Width="88" Height="38" HorizontalAlignment="Left" Background="#292524" BorderBrush="#292524" ToolTip="Play or pause preview (Space)" Click="RecordingPreviewPlay_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Grid Width="18" Height="18" Margin="0,0,7,0">
                                    <Path x:Name="ReviewPlayIcon" Data="M3,1 L16,9 L3,17 Z" Fill="White" Stretch="Fill"/>
                                    <Grid x:Name="ReviewPauseIcon" Visibility="Collapsed"><Path Data="M2,1 H7 V17 H2 Z M11,1 H16 V17 H11 Z" Fill="White" Stretch="Fill"/></Grid>
                                </Grid>
                                <TextBlock x:Name="ReviewPlayLabel" Text="Play" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Grid>
            </Border>

            <Border x:Name="ShortcutHints" Width="330" Background="#F2191D24" CornerRadius="13" Padding="16,13" IsHitTestVisible="False">
                <StackPanel>
                    <TextBlock Text="Capture shortcuts" Foreground="White" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
                    <TextBlock Text="W / A / S / D     Move cursor precisely" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock x:Name="DetectionWheelHint" Text="Mouse wheel      Parent / child UI element" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock x:Name="DetectionTabHint" Text="Tab                    Window / element mode" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="Shift + C            Recognize and copy text" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="L                        Long scrolling screenshot" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock Text="R                        Record selected region" Foreground="White" FontSize="13" Margin="0,3"/>
                    <TextBlock x:Name="DetectionModeText" Text="Mode: UI element" Foreground="#86B7FF" FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border x:Name="OcrPanel" Width="580" Height="390" Visibility="Collapsed" Background="White" BorderBrush="#E4E7EC" BorderThickness="1" CornerRadius="15" Padding="20">
                <Border.Effect><DropShadowEffect Color="#55000000" BlurRadius="20" ShadowDepth="5" Opacity="0.35"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right" Width="32" Height="32" Background="Transparent" BorderThickness="0" ToolTip="Close" Click="CloseOcr_Click"><Path Data="M5,5 L19,19 M19,5 L5,19" Stroke="#57534E" StrokeThickness="2" Stretch="Uniform" Margin="7"/></Button>
                        <StackPanel Orientation="Horizontal"><Border Width="28" Height="28" CornerRadius="6" Background="#E8F1FF" Margin="0,0,10,0"><TextBlock Text="A" Foreground="#3388FF" FontWeight="Bold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Text="Recognize text" Foreground="#101828" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/></StackPanel>
                    </DockPanel>
                    <TextBox x:Name="CaptureOcrResultBox" Grid.Row="1" Background="#F6F7F9" Foreground="#101828" BorderThickness="0" Padding="16,13" FontSize="16" FontFamily="Segoe UI" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                    <DockPanel Grid.Row="2" Margin="0,14,0,10">
                        <Button x:Name="OcrLayoutButton" DockPanel.Dock="Right" Content="Layout" Foreground="#1677FF" Background="Transparent" BorderThickness="0" Padding="6" Click="OcrLayout_Click"/>
                        <ComboBox x:Name="CaptureOcrLanguageBox" Width="230" Height="32" HorizontalAlignment="Left" SelectedValuePath="Tag" SelectionChanged="CaptureOcrLanguage_Changed">
                            <ComboBoxItem Content="Japanese" Tag="jpn"/><ComboBoxItem Content="English + Japanese" Tag="eng+jpn"/><ComboBoxItem Content="English + Chinese + Japanese" Tag="eng+chi_sim+chi_tra+jpn"/>
                            <ComboBoxItem Content="English" Tag="eng"/><ComboBoxItem Content="English + 简体中文" Tag="eng+chi_sim"/><ComboBoxItem Content="English + 繁體中文" Tag="eng+chi_tra"/><ComboBoxItem Content="English + 简体 + 繁體" Tag="eng+chi_sim+chi_tra"/>
                        </ComboBox>
                    </DockPanel>
                    <DockPanel Grid.Row="3">
                        <Button x:Name="CopyOcrButton" DockPanel.Dock="Right" Content="Copy" Width="86" Height="40" Background="#1677FF" Foreground="White" BorderThickness="0" Click="CopyOcr_Click"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Select area" Width="92" Height="36" Margin="0,0,7,0" Background="#FEC84B" Click="SelectOcrArea_Click"/>
                            <Button x:Name="RetryOcrButton" Content="Retry" Width="68" Height="36" Margin="0,0,10,0" Background="#D0D5DD" Click="RetryOcr_Click"/>
                            <CheckBox x:Name="OcrAutoCopyBox" Content="Auto-copy" Foreground="#57534E" VerticalAlignment="Center" Checked="OcrAutoCopy_Changed" Unchecked="OcrAutoCopy_Changed"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>
            <controls:AnnotationEditorControl x:Name="CaptureInlineEditor" Visibility="Collapsed" Panel.ZIndex="3000"/>
        </Canvas>
    </Grid>
</Window>
