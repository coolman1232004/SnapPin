<Window x:Class="SnapPin.Windows.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnapPin History" Width="920" Height="650" MinWidth="620" MinHeight="460"
        WindowStartupLocation="CenterOwner" Background="#101216" Foreground="White">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Capture history" FontSize="26" FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryText" Foreground="#98A2B3" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Repeat last region" Click="Repeat_Click" Margin="4,0" />
                <Button Content="Open folder" Click="OpenFolder_Click" Background="#BFDBFE" Margin="4,0" />
                <Button Content="Clear history" Click="Clear_Click" Background="#F97066" Margin="4,0" />
            </StackPanel>
        </DockPanel>
        <Border Grid.Row="1" Background="#191D24" CornerRadius="10" Padding="10" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Height="34" Padding="10,6" Margin="0,0,8,0" TextChanged="SearchBox_TextChanged"
                         ToolTip="Search OCR text, barcode content, source, dimensions, or date"/>
                <ComboBox x:Name="SourceFilterBox" Grid.Column="1" Width="128" Height="34" Margin="0,0,8,0" SelectedValuePath="Tag" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All sources" Tag="All" IsSelected="True"/><ComboBoxItem Content="Capture" Tag="Capture"/>
                    <ComboBoxItem Content="Copied" Tag="Copied"/><ComboBoxItem Content="Saved" Tag="Saved"/><ComboBoxItem Content="Pinned" Tag="Pinned"/>
                    <ComboBoxItem Content="Window" Tag="Window"/><ComboBoxItem Content="Scrolling" Tag="Scrolling"/><ComboBoxItem Content="OCR" Tag="OCR"/>
                    <ComboBoxItem Content="Recording" Tag="Recording"/><ComboBoxItem Content="Edited" Tag="Edited"/>
                </ComboBox>
                <ComboBox x:Name="TypeFilterBox" Grid.Column="2" Width="122" Height="34" Margin="0,0,8,0" SelectedValuePath="Tag" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All types" Tag="All" IsSelected="True"/><ComboBoxItem Content="Images" Tag="Images"/>
                    <ComboBoxItem Content="Recordings" Tag="Recordings"/><ComboBoxItem Content="OCR results" Tag="OCR"/>
                    <ComboBoxItem Content="Annotated" Tag="Annotated"/><ComboBoxItem Content="With context" Tag="Context"/>
                </ComboBox>
                <ComboBox x:Name="DateFilterBox" Grid.Column="3" Width="122" Height="34" SelectedValuePath="Tag" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Any date" Tag="All" IsSelected="True"/><ComboBoxItem Content="Today" Tag="Today"/>
                    <ComboBoxItem Content="Last 7 days" Tag="7"/><ComboBoxItem Content="Last 30 days" Tag="30"/>
                </ComboBox>
                <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="2,9,0,0">
                    <CheckBox x:Name="FavoriteOnlyBox" Content="Favourites only" Foreground="White" Margin="0,0,22,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="ShowRecycleBox" Content="Show recycle bin" Foreground="White" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <Button Content="Empty recycle bin" Click="EmptyRecycle_Click" Padding="9,3" Margin="18,-4,0,-4" Background="#F97066"/>
                </StackPanel>
            </Grid>
        </Border>
        <ListBox x:Name="HistoryList" Grid.Row="2" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="6"/><Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="252" Background="#191D24" CornerRadius="10" Padding="10" BorderBrush="#2D3642" BorderThickness="1">
                        <StackPanel>
                            <Border Height="142" Background="#0B0D10" CornerRadius="6" ClipToBounds="True">
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" MouseLeftButtonDown="Thumbnail_MouseLeftButtonDown" Tag="{Binding Id}" />
                            </Border>
                            <DockPanel Margin="2,9,2,7">
                                <TextBlock Text="{Binding SizeLabel}" Foreground="#98A2B3" FontSize="12" />
                                <TextBlock DockPanel.Dock="Right" Text="{Binding TimeLabel}" Foreground="#98A2B3" FontSize="12" HorizontalAlignment="Right" />
                            </DockPanel>
                            <DockPanel Margin="2,0,2,5">
                                <Button DockPanel.Dock="Right" Content="Name / tags" Click="Rename_Click" Tag="{Binding Id}" Padding="7,2" Margin="8,0,0,0" Background="#D0D5DD" FontSize="10" Visibility="{Binding ActiveVisibility}"/>
                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </DockPanel>
                            <DockPanel Margin="2,0,2,4">
                                <Button DockPanel.Dock="Right" Content="{Binding ContextLabel}" Visibility="{Binding ContextVisibility}"
                                        Click="ToggleContext_Click" Tag="{Binding Id}" Padding="7,3" Margin="8,0,0,0" Background="#BFDBFE" FontSize="10"/>
                                <TextBlock Text="{Binding SourceLabel}" Foreground="#63E6BE" FontSize="11" VerticalAlignment="Center" />
                            </DockPanel>
                            <TextBlock Text="{Binding RecognitionLabel}" Foreground="#63E6BE" FontSize="11" Margin="2,0,2,4" TextTrimming="CharacterEllipsis" />
                            <UniformGrid Columns="6" Visibility="{Binding ActiveVisibility}">
                                <Button Content="Copy" Click="Copy_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" />
                                <Button Content="Pin" Click="Pin_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" Background="#D9F99D" />
                                <Button Content="{Binding EditLabel}" Click="Edit_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" Background="#C4B5FD" />
                                <Button Content="⌗" ToolTip="Recognize text and QR/barcodes" Click="Recognize_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" Background="#FEC84B" FontSize="15" />
                                <Button Content="{Binding FavoriteGlyph}" ToolTip="Add or remove favourite" Click="Favorite_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" Background="#FDE68A" />
                                <Button Content="Delete" Click="Delete_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" Background="#F97066" />
                            </UniformGrid>
                            <UniformGrid Columns="2" Visibility="{Binding DeletedVisibility}">
                                <Button Content="Restore" Click="Restore_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" Background="#D9F99D"/>
                                <Button Content="Delete forever" Click="DeleteForever_Click" Tag="{Binding Id}" Padding="7,5" Margin="2" Background="#F97066"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
