<Window x:Class="SnapAnchor.Windows.PinnedImageWindow" Title="SnapAnchor Pin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SnapAnchor.Controls"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        AllowsTransparency="True" Background="Transparent" SnapsToDevicePixels="True" UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" MouseWheel="Window_MouseWheel"
        MouseRightButtonUp="Window_MouseRightButtonUp" KeyDown="Window_KeyDown">
    <Border x:Name="Frame" Background="#05000000" BorderThickness="0" CornerRadius="3" SnapsToDevicePixels="True" UseLayoutRounding="True">
        <Grid ClipToBounds="True">
            <Grid x:Name="PinnedImageSurface">
                <Image x:Name="PinnedImage" Stretch="Uniform" SnapsToDevicePixels="True" UseLayoutRounding="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                <Canvas x:Name="SelectableTextLayer" Visibility="Collapsed" Background="Transparent" Cursor="Arrow"
                        MouseLeftButtonDown="SelectableText_MouseLeftButtonDown"
                        MouseMove="SelectableText_MouseMove"
                        MouseLeave="SelectableText_MouseLeave"
                        MouseLeftButtonUp="SelectableText_MouseLeftButtonUp" Panel.ZIndex="20"/>
            </Grid>
            <ScrollViewer x:Name="LongImageViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly" PreviewMouseWheel="LongImageViewer_PreviewMouseWheel" Background="#08000000">
                <Grid x:Name="LongImageSurface" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image x:Name="LongPinnedImage" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top"
                           SnapsToDevicePixels="True" UseLayoutRounding="True" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <Canvas x:Name="LongSelectableTextLayer" Visibility="Collapsed" Background="Transparent" Cursor="Arrow"
                            MouseLeftButtonDown="SelectableText_MouseLeftButtonDown"
                            MouseMove="SelectableText_MouseMove"
                            MouseLeave="SelectableText_MouseLeave"
                            MouseLeftButtonUp="SelectableText_MouseLeftButtonUp" Panel.ZIndex="20"/>
                </Grid>
            </ScrollViewer>
            <controls:AnnotationEditorControl x:Name="InlineEditor" Visibility="Collapsed" />
            <controls:CropEditorControl x:Name="InlineCrop" Visibility="Collapsed" />
            <controls:RecognitionControl x:Name="InlineRecognition" Visibility="Collapsed" />
            <Border x:Name="ZoomBadge" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="#E8212530" CornerRadius="0,3,5,0" Padding="8,4" Panel.ZIndex="50" IsHitTestVisible="False">
                <TextBlock x:Name="ZoomText" Text="100%" Foreground="White" FontSize="11" FontWeight="SemiBold" />
            </Border>
            <Border x:Name="ClickThroughBadge" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="#DD191D24" CornerRadius="0,3,0,5" Padding="8,4">
                <TextBlock Text="click-through" Foreground="White" FontSize="11" />
            </Border>
            <Border x:Name="PinStateBadge" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,27,0,0"
                    Background="#DDF5F2ED" BorderBrush="#5578716C" BorderThickness="1" CornerRadius="5,0,0,5" Padding="7,3" Panel.ZIndex="60" IsHitTestVisible="False">
                <TextBlock x:Name="PinStateText" Foreground="#1C1917" FontSize="10.5" FontWeight="SemiBold"/>
            </Border>
            <Border x:Name="ShadeHeader" Visibility="Collapsed" Background="#F5FAF9F7" BorderBrush="#5578716C" BorderThickness="0,0,0,1" Panel.ZIndex="80">
                <DockPanel Margin="8,0">
                    <TextBlock Text="SnapAnchor" Foreground="#292524" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ShadeTitleText" Text="Pinned image" Foreground="#1C1917" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
            <Border x:Name="TitleEditor" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="8"
                    Background="#F8FFFFFF" BorderBrush="#78716C" BorderThickness="1" CornerRadius="5" Padding="5" Panel.ZIndex="150">
                <TextBox x:Name="TitleEditorBox" MinWidth="180" MaxWidth="360" Height="27" Padding="5,2" BorderThickness="0"
                         KeyDown="TitleEditorBox_KeyDown" LostKeyboardFocus="TitleEditorBox_LostKeyboardFocus"/>
            </Border>
            <Border x:Name="TextSelectionToolbar" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="#EE20242B" CornerRadius="8" Padding="5" Panel.ZIndex="100">
                <StackPanel Orientation="Horizontal">
                    <Button Width="72" Height="34" Padding="5,2" Foreground="White" Background="Transparent" BorderThickness="0"
                            ToolTip="Copy selected text" Click="CopySelectedText_Click">
                        <StackPanel Orientation="Horizontal"><Path Width="15" Height="15" Margin="0,0,5,0" Data="M4,7 H17 V21 H4 Z M8,3 H21 V17" Stroke="White" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"/><TextBlock Text="Copy" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Width="76" Height="34" Padding="5,2" Foreground="White" Background="Transparent" BorderThickness="0"
                            ToolTip="Copy all recognized text" Click="CopyAllRecognizedText_Click">
                        <StackPanel Orientation="Horizontal"><Path Width="15" Height="15" Margin="0,0,5,0" Data="M4,5 H20 M4,10 H20 M4,15 H15 M4,20 H17" Stroke="White" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"/><TextBlock Text="All text" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button x:Name="CancelTextSelectionButton" Width="72" Height="34" Padding="5,2" Foreground="White" Background="Transparent" BorderThickness="0"
                            ToolTip="Cancel" Click="CancelTextSelection_Click">
                        <StackPanel Orientation="Horizontal"><Path Width="15" Height="15" Margin="0,0,5,0" Data="M5,5 L19,19 M19,5 L5,19" Stroke="White" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"/><TextBlock Text="Cancel" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </StackPanel>
            </Border>
            <Border x:Name="PinOutline" BorderBrush="#44000000" BorderThickness="1" CornerRadius="3"
                    IsHitTestVisible="False" Panel.ZIndex="300" SnapsToDevicePixels="True"/>
        </Grid>
    </Border>
</Window>
