<Window x:Class="SnapPin.Windows.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnapPin Preferences" Width="680" Height="540" MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner" Background="#FFFFFF" Foreground="#111827" FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/><Setter Property="MinHeight" Value="28"/><Setter Property="Padding" Value="12,5"/>
            <Setter Property="Foreground" Value="#111827"/><Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Opacity" Value="0.85"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Surface" Property="Opacity" Value="0.7"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="AccentDialogButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#2C978E"/><Setter Property="BorderBrush" Value="#2C978E"/>
        </Style>
        <Style TargetType="TextBox"><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="BorderBrush" Value="#C9D0D9"/><Setter Property="Background" Value="White"/><Setter Property="MaxHeight" Value="28"/></Style>
        <Style TargetType="ComboBox"><Setter Property="BorderBrush" Value="#C9D0D9"/><Setter Property="Background" Value="White"/><Setter Property="MaxHeight" Value="28"/></Style>
        <Style TargetType="TabControl"><Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#D7DCE3"/></Style>
        <Style TargetType="TabItem"><Setter Property="Padding" Value="8,4"/></Style>
    </Window.Resources>
    <DockPanel Margin="10" Background="White">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,9,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource DialogButton}" Margin="0,0,9,0" />
            <Button Content="Save changes" Click="Save_Click" Style="{StaticResource AccentDialogButton}" />
        </StackPanel>
        <TabControl x:Name="Tabs">
            <TabItem Header="General">
                <StackPanel Margin="18">
                    <TextBlock Text="Application" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <DockPanel Margin="0,3,0,8" LastChildFill="False">
                        <TextBlock Text="Interface language" Width="150" VerticalAlignment="Center"/>
                        <ComboBox x:Name="UiLanguageBox" Width="160" Height="28" SelectedValuePath="Tag">
                            <ComboBoxItem Content="English" Tag="English"/>
                            <ComboBoxItem Content="简体中文" Tag="简体中文"/>
                            <ComboBoxItem Content="繁體中文" Tag="繁體中文"/>
                        </ComboBox>
                    </DockPanel>
                    <CheckBox x:Name="RunOnStartupBox" Content="Run SnapPin on system startup" Margin="0,5" />
                    <CheckBox x:Name="RunAsAdministratorBox" Content="Always launch SnapPin as administrator" Margin="0,5" ToolTip="Windows will display a User Account Control prompt when SnapPin starts" />
                    <TextBlock Text="Applies the next time SnapPin starts. Windows will show a UAC confirmation prompt." Foreground="#667085" FontSize="11" Margin="22,-1,0,4" />
                    <CheckBox x:Name="AutoBackupBox" Content="Back up open pins and settings automatically" Margin="0,5" />
                    <CheckBox x:Name="KeepResponsiveBox" Content="Keep SnapPin running in the notification area when the dashboard closes" Margin="0,5" />
                    <Border Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="8" Padding="13" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Configuration storage" FontWeight="SemiBold" />
                            <TextBlock Text="Settings are stored locally under your Windows user profile. No account or cloud connection is used." TextWrapping="Wrap" Foreground="#667085" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
            <TabItem Header="Capture">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="18" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Selection border width" VerticalAlignment="Center" Margin="0,8" />
                    <TextBox x:Name="BorderWidthBox" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Margin="0,6" Padding="7,5" />
                    <TextBlock Grid.Row="1" Text="Selection border color" VerticalAlignment="Center" Margin="0,8" />
                    <TextBox x:Name="BorderColorBox" Grid.Row="1" Grid.Column="1" Width="130" Height="32" HorizontalAlignment="Left" Margin="0,6" Padding="7,5" />
                    <TextBlock Grid.Row="2" Text="Screen mask color (ARGB)" VerticalAlignment="Center" Margin="0,8" />
                    <TextBox x:Name="MaskColorBox" Grid.Row="2" Grid.Column="1" Width="130" Height="32" HorizontalAlignment="Left" Margin="0,6" Padding="7,5" />
                    <CheckBox x:Name="CrossLinesBox" Grid.Row="3" Grid.ColumnSpan="2" Content="Show full-screen cross lines at the cursor" Margin="0,9" />
                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,5">
                        <CheckBox x:Name="ShowSizeBox" Content="Show coordinate and size badge above the selection" Margin="0,4" />
                        <CheckBox x:Name="ShowElementDetectionBox" Content="Show automatic window and UI-element detection outline" Margin="0,4" />
                        <CheckBox x:Name="ShowCaptureHintsBox" Content="Show capture shortcut hints" Margin="0,4" />
                    </StackPanel>
                    <TextBlock Grid.Row="5" Text="Long capture frames" VerticalAlignment="Center" Margin="0,8" />
                    <TextBox x:Name="ScrollFramesBox" Grid.Row="5" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Margin="0,6" Padding="7,5" />
                    <TextBlock Grid.Row="6" Text="Scroll pause (ms)" VerticalAlignment="Center" Margin="0,8" />
                    <TextBox x:Name="ScrollDelayBox" Grid.Row="6" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Margin="0,6" Padding="7,5" />
                    <TextBlock Grid.Row="7" Text="Wheel clicks per frame" VerticalAlignment="Center" Margin="0,8" />
                    <TextBox x:Name="ScrollClicksBox" Grid.Row="7" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Margin="0,6" Padding="7,5" />
                    <Separator Grid.Row="8" Grid.ColumnSpan="2" Margin="0,12,0,8"/>
                    <CheckBox x:Name="ExcludeSnapPinBox" Grid.Row="9" Grid.ColumnSpan="2" Content="Exclude SnapPin pins and controls from screenshots and recordings" Margin="0,7"/>
                    <TextBlock Grid.Row="10" Text="Exclude a running app" VerticalAlignment="Center" Margin="0,8"/>
                    <DockPanel Grid.Row="10" Grid.Column="1" Margin="0,4">
                        <Button DockPanel.Dock="Right" Content="Add" Click="AddExcludedApp_Click" Style="{StaticResource AccentDialogButton}" Margin="8,0,0,0" Padding="13,5"/>
                        <ComboBox x:Name="RunningAppsBox" Height="32" DisplayMemberPath="DisplayName" SelectedValuePath="ProcessName"/>
                    </DockPanel>
                    <TextBlock Grid.Row="11" Text="Covered in still screenshots" VerticalAlignment="Top" Margin="0,10"/>
                    <Grid Grid.Row="11" Grid.Column="1" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <ListBox x:Name="ExcludedAppsList" Height="74"/>
                        <Button Grid.Column="1" Content="Remove" Click="RemoveExcludedApp_Click" Style="{StaticResource DialogButton}" Margin="8,0,0,0" Padding="11,5" VerticalAlignment="Top"/>
                    </Grid>
                    <TextBlock Grid.Row="12" Grid.ColumnSpan="2" Text="Windows lets SnapPin hide its own windows from video capture. Other applications are securely covered in still screenshots; video exclusion also requires privacy support from that application." Foreground="#667085" TextWrapping="Wrap" Margin="0,8,0,4"/>
                </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Toolbar">
                <Grid Margin="12" VerticalAlignment="Top">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Toolbar size" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="ToolbarSizeBox" Width="132" Height="29" SelectedValuePath="Tag">
                            <ComboBoxItem Content="Compact" Tag="Compact"/>
                            <ComboBoxItem Content="Standard" Tag="Standard"/>
                            <ComboBoxItem Content="Large" Tag="Large"/>
                        </ComboBox>
                        <TextBlock Text="Automatically follows Windows display scaling." Foreground="#667085" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <StackPanel x:Name="AnnotationToolbarSettingsPanel" Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="Annotation toolbar" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Drawing tools shown directly in the first capture row." Foreground="#667085" Margin="0,4,0,8"/>
                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="248"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <ListBox x:Name="ToolbarToolsList" Height="235" BorderBrush="#C9D0D9" BorderThickness="1" SelectionMode="Single"/>
                            <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                <Button Content="▲" ToolTip="Move up" Click="MoveToolbarUp_Click" Style="{StaticResource DialogButton}" Width="36" Margin="0,0,0,6"/>
                                <Button Content="▼" ToolTip="Move down" Click="MoveToolbarDown_Click" Style="{StaticResource DialogButton}" Width="36"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Enable all" Click="EnableAllToolbar_Click" Style="{StaticResource DialogButton}" Margin="0,0,7,0"/>
                            <Button Content="Default" Click="ResetToolbar_Click" Style="{StaticResource DialogButton}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel x:Name="CaptureToolbarSettingsPanel" Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Capture toolbar" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Output actions shown after the drawing tools." Foreground="#667085" Margin="0,4,0,8"/>
                        <Grid HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="248"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <ListBox x:Name="CaptureToolbarToolsList" Height="235" BorderBrush="#C9D0D9" BorderThickness="1" SelectionMode="Single"/>
                            <StackPanel Grid.Column="1" Margin="7,0,0,0">
                                <Button Content="▲" ToolTip="Move up" Click="MoveCaptureToolbarUp_Click" Style="{StaticResource DialogButton}" Width="36" Margin="0,0,0,6"/>
                                <Button Content="▼" ToolTip="Move down" Click="MoveCaptureToolbarDown_Click" Style="{StaticResource DialogButton}" Width="36"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Enable all" Click="EnableAllCaptureToolbar_Click" Style="{StaticResource DialogButton}" Margin="0,0,7,0"/>
                            <Button Content="Default" Click="ResetCaptureToolbar_Click" Style="{StaticResource DialogButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Recording">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="18" VerticalAlignment="Top">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="215"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Text="Output format" VerticalAlignment="Center" Margin="0,7"/><ComboBox x:Name="RecordingFormatBox" Grid.Column="1" Height="32" Margin="0,4" SelectedValuePath="Tag"><ComboBoxItem Content="MP4 video (H.264)" Tag="MP4"/><ComboBoxItem Content="Animated GIF" Tag="GIF"/></ComboBox>
                        <TextBlock Grid.Row="1" Text="Capture mode" VerticalAlignment="Center" Margin="0,7"/><ComboBox x:Name="RecordingModeBox" Grid.Row="1" Grid.Column="1" Height="32" Margin="0,4" SelectedValuePath="Tag"><ComboBoxItem Content="Selected region" Tag="Region"/><ComboBoxItem Content="Detected window" Tag="Window"/><ComboBoxItem Content="Full screen" Tag="FullScreen"/></ComboBox>
                        <TextBlock Grid.Row="2" Text="MP4 quality" VerticalAlignment="Center" Margin="0,7"/><ComboBox x:Name="RecordingQualityBox" Grid.Row="2" Grid.Column="1" Height="32" Margin="0,4" SelectedValuePath="Tag"><ComboBoxItem Content="Compact · 24 fps · 3 Mbps" Tag="Compact"/><ComboBoxItem Content="Standard · 30 fps · 6 Mbps" Tag="Standard"/><ComboBoxItem Content="High · 60 fps · 10 Mbps" Tag="High"/></ComboBox>
                        <TextBlock Grid.Row="3" Text="GIF frames per second" VerticalAlignment="Center" Margin="0,7"/><TextBox x:Name="RecordingFpsBox" Grid.Row="3" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Padding="7,5" Margin="0,4"/>
                        <TextBlock Grid.Row="4" Text="Countdown / max duration" VerticalAlignment="Center" Margin="0,7"/><StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal"><TextBox x:Name="RecordingCountdownBox" Width="64" Height="32" Padding="7,5" Margin="0,4" ToolTip="Countdown seconds"/><TextBlock Text="s  /" VerticalAlignment="Center" Margin="7,0"/><TextBox x:Name="RecordingDurationBox" Width="76" Height="32" Padding="7,5" Margin="0,4" ToolTip="Maximum duration seconds"/><TextBlock Text="s" VerticalAlignment="Center" Margin="7,0"/></StackPanel>
                        <TextBlock Grid.Row="5" Text="GIF maximum width" VerticalAlignment="Center" Margin="0,7"/><TextBox x:Name="RecordingWidthBox" Grid.Row="5" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Padding="7,5" Margin="0,4"/>
                        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,7"><CheckBox x:Name="RecordingCursorBox" Content="Mouse cursor" Margin="0,0,22,0"/><CheckBox x:Name="RecordingClickBox" Content="Highlight clicks"/></StackPanel>
                        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,7"><CheckBox x:Name="RecordingSystemAudioBox" Content="System audio" Margin="0,0,22,0"/><CheckBox x:Name="RecordingMicrophoneBox" Content="Microphone"/></StackPanel>
                        <TextBlock Grid.Row="8" Text="System audio device" VerticalAlignment="Center" Margin="0,7"/><ComboBox x:Name="RecordingOutputDeviceBox" Grid.Row="8" Grid.Column="1" Height="32" Margin="0,4" DisplayMemberPath="DisplayName" SelectedValuePath="DeviceName"/>
                        <TextBlock Grid.Row="9" Text="Microphone device" VerticalAlignment="Center" Margin="0,7"/><ComboBox x:Name="RecordingInputDeviceBox" Grid.Row="9" Grid.Column="1" Height="32" Margin="0,4" DisplayMemberPath="DisplayName" SelectedValuePath="DeviceName"/>
                        <TextBlock Grid.Row="10" Text="Recording folder" VerticalAlignment="Center" Margin="0,7"/><DockPanel Grid.Row="10" Grid.Column="1" Margin="0,4"><Button DockPanel.Dock="Right" Content="Browse" Click="BrowseRecording_Click" Style="{StaticResource AccentDialogButton}" Margin="8,0,0,0"/><TextBox x:Name="RecordingFolderBox" Height="32" Padding="7,5"/></DockPanel>
                        <TextBlock Grid.Row="11" Grid.ColumnSpan="2" Text="MP4 uses Windows Media Foundation and stays entirely on this computer." Foreground="#667085" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Pins">
                <Grid Margin="18" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <CheckBox x:Name="PinShadowBox" Grid.ColumnSpan="2" Content="Show a shadow around pinned windows" Margin="0,8" />
                    <TextBlock Grid.Row="1" Text="Default opacity (%)" VerticalAlignment="Center" Margin="0,10" />
                    <TextBox x:Name="PinOpacityBox" Grid.Row="1" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Margin="0,7" Padding="7,5" />
                    <TextBlock Grid.Row="2" Text="Maximum window size" VerticalAlignment="Center" Margin="0,10" />
                    <TextBox x:Name="PinMaxSizeBox" Grid.Row="2" Grid.Column="1" Width="110" Height="32" HorizontalAlignment="Left" Margin="0,7" Padding="7,5" />
                    <TextBlock Grid.Row="3" Text="Fast thumbnail size" VerticalAlignment="Center" Margin="0,10" />
                    <TextBox x:Name="ThumbnailSizeBox" Grid.Row="3" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Margin="0,7" Padding="7,5" />
                    <TextBlock Grid.Row="4" Text="Pin groups" VerticalAlignment="Center" Margin="0,10" />
                    <TextBox x:Name="PinGroupsBox" Grid.Row="4" Grid.Column="1" Height="32" Margin="0,7" Padding="7,5" IsReadOnly="True" ToolTip="Manage named groups from the Pins tab on the SnapPin dashboard" />
                    <TextBlock Grid.Row="5" Text="Transparent background" VerticalAlignment="Center" Margin="0,10" />
                    <ComboBox x:Name="PinBackgroundBox" Grid.Row="5" Grid.Column="1" Height="34" Margin="0,7" SelectedValuePath="Tag">
                        <ComboBoxItem Content="Transparent" Tag="Transparent"/><ComboBoxItem Content="Pseudo-transparent" Tag="Pseudo"/>
                        <ComboBoxItem Content="Dark checkerboard" Tag="DarkChecker"/><ComboBoxItem Content="Light checkerboard" Tag="LightChecker"/>
                    </ComboBox>
                    <CheckBox x:Name="DesktopGroupsBox" Grid.Row="6" Grid.ColumnSpan="2" Content="Switch bound pin groups automatically with Windows virtual desktops" Margin="0,10,0,0"/>
                    <CheckBox x:Name="PinTextSelectableDefaultBox" Grid.Row="7" Grid.ColumnSpan="2"
                              Content="Make new pinned images text-selectable by default (local OCR)" Margin="0,10,0,0"
                              ToolTip="Automatically recognizes positioned text when a new pin opens. Each pin can still override this from its right-click menu."/>
                </Grid>
            </TabItem>
            <TabItem Header="History">
                <StackPanel Margin="18">
                    <TextBlock Text="Capture history" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />
                    <TextBlock Text="Maximum saved captures" />
                    <TextBox x:Name="HistoryLimitBox" Width="110" Height="32" HorizontalAlignment="Left" Padding="7,5" Margin="0,6,0,12" />
                    <TextBlock Text="Completed captures are stored locally. When the limit is reached, the oldest captures are removed automatically." Foreground="#667085" TextWrapping="Wrap" MaxWidth="500" HorizontalAlignment="Left" LineHeight="20" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Output">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18">
                    <TextBlock Text="Naming and saving" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="File name template" />
                    <TextBox x:Name="FileNameBox" Height="32" Padding="7,5" Margin="0,5,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Default image format"/>
                            <ComboBox x:Name="OutputFormatBox" Height="34" Margin="0,5,0,0" SelectedValuePath="Tag">
                                <ComboBoxItem Content="PNG (lossless)" Tag="PNG"/><ComboBoxItem Content="JPEG" Tag="JPEG"/><ComboBoxItem Content="WebP" Tag="WEBP"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="JPEG / WebP quality"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock x:Name="ImageQualityText" Text="92"/>
                                    <TextBlock Text="%"/>
                                </StackPanel>
                            </Grid>
                            <Slider x:Name="ImageQualitySlider" Minimum="30" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,9,0,0" ValueChanged="ImageQualitySlider_Changed"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Quick-save folder" />
                    <DockPanel Margin="0,5,0,12"><Button DockPanel.Dock="Right" Content="Browse" Click="BrowseQuick_Click" Style="{StaticResource AccentDialogButton}" Margin="8,0,0,0"/><TextBox x:Name="QuickFolderBox" Height="32" Padding="7,5" /></DockPanel>
                    <CheckBox x:Name="SaveNotificationBox" Content="Show a notification after quick save" Margin="0,5,0,14" />
                    <CheckBox x:Name="AutoSaveBox" Content="Automatically save every completed capture" Margin="0,5,0,10" />
                    <TextBlock Text="Automatic-save folder" />
                    <DockPanel Margin="0,5,0,0"><Button DockPanel.Dock="Right" Content="Browse" Click="BrowseAuto_Click" Style="{StaticResource AccentDialogButton}" Margin="8,0,0,0"/><TextBox x:Name="AutoFolderBox" Height="32" Padding="7,5" /></DockPanel>
                    <TextBlock Text="Tokens: $yyyy  $MM  $dd  $HH  $mm  $ss" Foreground="#667085" Margin="0,12,0,0" />
                    <Separator Margin="0,14,0,10"/>
                    <TextBlock Text="Export appearance" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Text="Border width" VerticalAlignment="Center" Margin="0,7"/>
                        <TextBox x:Name="OutputBorderWidthBox" Grid.Column="1" Width="90" Height="32" HorizontalAlignment="Left" Padding="7,5" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Text="Border color (ARGB)" VerticalAlignment="Center" Margin="0,7"/>
                        <TextBox x:Name="OutputBorderColorBox" Grid.Row="1" Grid.Column="1" Width="130" Height="32" HorizontalAlignment="Left" Padding="7,5" Margin="0,4"/>
                        <CheckBox x:Name="OutputShadowBox" Grid.Row="2" Grid.ColumnSpan="2" Content="Include a shadow when saving or copying as files" Margin="0,8"/>
                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,8">
                            <TextBlock Text="Shadow size" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="OutputShadowSizeBox" Width="70" Height="32" Padding="7,5"/>
                            <TextBlock Text="Shadow color" VerticalAlignment="Center" Margin="24,0,10,0"/>
                            <TextBox x:Name="OutputShadowColorBox" Width="130" Height="32" Padding="7,5"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Hotkeys">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="18" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Capture" VerticalAlignment="Center" Margin="0,8"/><ComboBox x:Name="CaptureHotkeyBox" Grid.Column="1" Height="34" Margin="0,6" DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                    <TextBlock Grid.Row="1" Text="Capture and copy" VerticalAlignment="Center" Margin="0,8"/><ComboBox x:Name="CopyHotkeyBox" Grid.Row="1" Grid.Column="1" Height="34" Margin="0,6" DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                    <TextBlock Grid.Row="2" Text="Custom capture" VerticalAlignment="Center" Margin="0,8"/><ComboBox x:Name="CustomHotkeyBox" Grid.Row="2" Grid.Column="1" Height="34" Margin="0,6" DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                    <TextBlock Grid.Row="3" Text="Draw on screen" VerticalAlignment="Center" Margin="0,8"/><ComboBox x:Name="DrawingHotkeyBox" Grid.Row="3" Grid.Column="1" Height="34" Margin="0,6" DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                    <TextBlock Grid.Row="4" Text="Pin clipboard" VerticalAlignment="Center" Margin="0,8"/><ComboBox x:Name="PasteHotkeyBox" Grid.Row="4" Grid.Column="1" Height="34" Margin="0,6" DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                    <TextBlock Grid.Row="5" Text="Hide/show all pins" VerticalAlignment="Center" Margin="0,8"/><ComboBox x:Name="TogglePinsHotkeyBox" Grid.Row="5" Grid.Column="1" Height="34" Margin="0,6" DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                    <TextBlock Grid.Row="6" Text="Record region" VerticalAlignment="Center" Margin="0,8"/><ComboBox x:Name="RecordingHotkeyBox" Grid.Row="6" Grid.Column="1" Height="34" Margin="0,6" DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                    <Separator Grid.Row="7" Grid.ColumnSpan="2" Margin="0,10,0,8"/>
                    <TextBlock Grid.Row="8" Text="Ignore shortcuts in app" VerticalAlignment="Center" Margin="0,8"/>
                    <DockPanel Grid.Row="8" Grid.Column="1" Margin="0,4">
                        <Button DockPanel.Dock="Right" Content="Add" Click="AddHotkeyExcludedApp_Click" Style="{StaticResource AccentDialogButton}" Margin="8,0,0,0" Padding="13,5"/>
                        <ComboBox x:Name="HotkeyRunningAppsBox" Height="32" DisplayMemberPath="DisplayName" SelectedValuePath="ProcessName"/>
                    </DockPanel>
                    <TextBlock Grid.Row="9" Text="Excluded apps" VerticalAlignment="Top" Margin="0,10"/>
                    <Grid Grid.Row="9" Grid.Column="1" Margin="0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <ListBox x:Name="HotkeyExcludedAppsList" Height="74"/>
                        <Button Grid.Column="1" Content="Remove" Click="RemoveHotkeyExcludedApp_Click" Style="{StaticResource DialogButton}" Margin="8,0,0,0" Padding="11,5" VerticalAlignment="Top"/>
                    </Grid>
                    <TextBlock Grid.Row="10" Grid.ColumnSpan="2" Text="The emergency Alt+Shift+P shortcut always remains available so click-through pins can be recovered." Foreground="#667085" TextWrapping="Wrap" Margin="0,8,0,4"/>
                </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="OCR">
                <StackPanel Margin="18">
                    <TextBlock Text="Local recognition" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />
                    <TextBlock Text="OCR language" />
                    <ComboBox x:Name="OcrLanguageBox" Width="240" Height="34" HorizontalAlignment="Left" Margin="0,6,0,14" SelectedValuePath="Tag">
                        <ComboBoxItem Content="Japanese" Tag="jpn"/>
                        <ComboBoxItem Content="English + Japanese" Tag="eng+jpn"/>
                        <ComboBoxItem Content="English + Chinese + Japanese" Tag="eng+chi_sim+chi_tra+jpn"/>
                        <ComboBoxItem Content="English" Tag="eng"/>
                        <ComboBoxItem Content="English + 简体中文" Tag="eng+chi_sim"/>
                        <ComboBoxItem Content="English + 繁體中文" Tag="eng+chi_tra"/>
                        <ComboBoxItem Content="English + 简体 + 繁體" Tag="eng+chi_sim+chi_tra"/>
                    </ComboBox>
                    <Border Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="8" Padding="13">
                        <StackPanel>
                            <TextBlock Text="Private by design" FontWeight="SemiBold" />
                            <TextBlock Text="Text and QR/barcode recognition runs on this computer. Images are not uploaded to a cloud service." TextWrapping="Wrap" Foreground="#667085" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
            <TabItem Header="About">
                <StackPanel Margin="22">
                    <TextBlock Text="SnapPin" FontSize="27" FontWeight="Bold" Foreground="#0F766E" />
                    <DockPanel Margin="0,2,0,3">
                        <Button x:Name="CopyVersionButton" DockPanel.Dock="Right" Content="Copy version information" Style="{StaticResource DialogButton}" Click="CopyVersion_Click" Margin="12,0,0,0"/>
                        <StackPanel>
                            <TextBlock x:Name="VersionText" Text="Version" Foreground="#667085"/>
                            <TextBlock x:Name="EditionText" Foreground="#667085" Margin="0,3,0,0"/>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock Text="Local-first capture and floating visual references" FontSize="15" Margin="0,7,0,15" />
                    <TextBlock Text="This is an independent implementation built with documented Windows APIs. It contains no Snipaste code, branding, or assets." TextWrapping="Wrap" Foreground="#667085" LineHeight="22" />
                    <Border Background="#F8FAFC" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,18,0,12">
                        <StackPanel>
                            <TextBlock Text="Diagnostics and recovery" FontWeight="SemiBold"/>
                            <TextBlock Text="Unexpected errors are logged locally. Logs are retained for 14 days and open pins use verified generation backups." Foreground="#667085" TextWrapping="Wrap" Margin="0,5,0,9"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Open diagnostics folder" Style="{StaticResource DialogButton}" Click="OpenDiagnostics_Click" Margin="0,0,8,0"/>
                                <Button Content="Copy system summary" Style="{StaticResource DialogButton}" Click="CopyDiagnostics_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="GitHub updates" FontWeight="SemiBold"/>
                    <CheckBox x:Name="CheckUpdatesOnStartupBox" Content="Check for updates when SnapPin starts" Margin="0,8,0,0"/>
                    <DockPanel Margin="0,7,0,0">
                        <Button DockPanel.Dock="Right" Content="Check now" Style="{StaticResource AccentDialogButton}" Click="CheckUpdates_Click" Margin="12,0,0,0"/>
                        <TextBlock VerticalAlignment="Center" Foreground="#667085">
                            <Run Text="Updates are published on "/>
                            <Hyperlink NavigateUri="https://github.com/coolman1232004/SnapPin" RequestNavigate="GitHubLink_RequestNavigate">GitHub</Hyperlink>
                            <Run Text="."/>
                        </TextBlock>
                    </DockPanel>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
