<Window x:Class="SnapAnchor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnapAnchor" Icon="pack://application:,,,/SnapAnchor;component/Assets/SnapAnchor-icon-512.png"
        Height="700" Width="920" MinHeight="600" MinWidth="760"
        Background="#EBF2F5" Foreground="#11181D"
        FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#EBF2F5"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FEFEFE"/>
        <SolidColorBrush x:Key="TextBrush" Color="#11181D"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#52636C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2C978E"/>
        <SolidColorBrush x:Key="LogoAccentBrush" Color="#41BBAC"/>
        <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#C5E6F7"/>
        <SolidColorBrush x:Key="NeutralBrush" Color="#D1D9DC"/>
        <SolidColorBrush x:Key="BottomBarBrush" Color="#BED7E3"/>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="18,11"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border x:Name="ButtonSurface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonSurface" Property="Opacity" Value="0.88"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonSurface" Property="Opacity" Value="0.72"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource NeutralBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect">
                <Setter.Value><DropShadowEffect Color="#260F2933" BlurRadius="15" ShadowDepth="3" Opacity="0.34"/></Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabSurface" Background="{TemplateBinding Background}" CornerRadius="8,8,0,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="TabSurface" Property="Background" Value="{StaticResource PanelBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TabSurface" Property="Background" Value="#DCECF3"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="32,26,32,20" Background="{StaticResource PageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Border Width="64" Height="64" CornerRadius="16" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BottomBarBrush}" BorderThickness="1" Margin="0,0,18,0">
                <Image x:Name="AppLogoImage" Source="pack://application:,,,/SnapAnchor;component/Assets/SnapAnchor-icon-512.png" Width="50" Height="50" Stretch="Uniform"/>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="SNAPANCHOR" Foreground="{StaticResource LogoAccentBrush}" FontWeight="Bold" FontSize="13"/>
                <TextBlock Text="Capture it. Keep it in sight." Foreground="{StaticResource TextBrush}" FontSize="31" FontWeight="SemiBold" Margin="0,4,0,2"/>
                <TextBlock Text="A local-first screenshot and floating-reference tool for Windows." Foreground="{StaticResource MutedBrush}" FontSize="14"/>
            </StackPanel>
            <Button x:Name="DrawScreenButton" Grid.Column="2" Visibility="Collapsed" Content="Draw on screen" Click="DrawScreenButton_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,24,0,20">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Button x:Name="CaptureButton" Height="52" Content="Capture region  ·  Print Screen" Click="CaptureButton_Click" Margin="0,0,10,0" FontSize="14"/>
            <Button x:Name="PinClipboardButton" Grid.Column="1" Height="52" Content="Pin clipboard  ·  F3" Click="PinButton_Click" Margin="10,0,0,0" Background="{StaticResource SecondaryAccentBrush}" Foreground="{StaticResource TextBrush}" FontSize="14"/>
        </Grid>

        <TabControl x:Name="DashboardTabs" Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0">
            <TabItem Header="Overview">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border x:Name="CaptureOverviewCard" Style="{StaticResource DashboardCard}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="01" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Capture" FontSize="19" FontWeight="SemiBold" Margin="0,12,0,7"/>
                            <TextBlock Text="Drag any region across one or more displays. Copy, save, or pin the result." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource DashboardCard}" Margin="5,0">
                        <StackPanel>
                            <TextBlock Text="02" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Pin" FontSize="19" FontWeight="SemiBold" Margin="0,12,0,7"/>
                            <TextBlock Text="Keep images, image files, text, or hex colors in borderless topmost windows." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource DashboardCard}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="03" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Control" FontSize="19" FontWeight="SemiBold" Margin="0,12,0,7"/>
                            <TextBlock Text="Drag to move, scroll to resize, Ctrl+scroll for opacity, and right-click for tools." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Pins">
                <Border Style="{StaticResource DashboardCard}" Margin="0,10,0,0" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="Organize floating references into groups. A group can follow a Windows virtual desktop automatically."
                                   Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="Group" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <ComboBox x:Name="PinGroupsCombo" Width="145" Height="32" SelectionChanged="PinGroup_SelectionChanged"/>
                                <TextBox x:Name="NewPinGroupBox" Width="130" Height="32" Padding="7,5" Margin="10,0,0,0" ToolTip="New group name"/>
                                <Button Content="+" Click="AddPinGroup_Click" Width="34" Height="32" Padding="0" Margin="5,0,0,0" ToolTip="Add group"/>
                                <Button Content="−" Click="DeletePinGroup_Click" Width="34" Height="32" Padding="0" Margin="5,0,0,0" Background="{StaticResource NeutralBrush}" Foreground="{StaticResource TextBrush}" ToolTip="Delete current group"/>
                                <TextBlock x:Name="PinManagerStatus" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Margin="12,0,0,0"/>
                            </DockPanel>
                            <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="Hide / show" Click="ToggleManagedPins_Click" Padding="11,6" Margin="7,0,0,0"/>
                                    <Button Content="Close group" Click="CloseManagedPins_Click" Padding="11,6" Margin="7,0,0,0" Background="#FECACA"/>
                                </StackPanel>
                                <TextBlock x:Name="PinDesktopStatus" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                                <Button Content="Link desktop" Click="BindPinGroupDesktop_Click" Padding="11,6" Margin="9,0,0,0"/>
                                <Button Content="Remove link" Click="ClearPinGroupDesktop_Click" Padding="11,6" Margin="6,0,0,0" Background="{StaticResource NeutralBrush}" Foreground="{StaticResource TextBrush}"/>
                            </DockPanel>
                        </Grid>
                        <ListBox x:Name="PinManagerList" Grid.Row="2" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="145" Height="120" Background="#F7FAFB" BorderBrush="{StaticResource NeutralBrush}" BorderThickness="1" CornerRadius="9" Margin="0,0,9,9" Padding="7">
                                        <Grid>
                                            <Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                            <Image Source="{Binding Image}" Stretch="Uniform"/>
                                            <Grid Grid.Row="1" Margin="0,5,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center"><TextBlock Text="{Binding SizeLabel}" FontSize="11" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="{Binding VisibilityLabel}" FontSize="10" Foreground="{StaticResource MutedBrush}"/></StackPanel>
                                                <Button Grid.Column="1" Content="↗" Tag="{Binding Id}" Click="ActivateManagedPin_Click" Width="28" Height="28" Padding="0" Margin="3,0" ToolTip="Show this pin"/>
                                                <Button Grid.Column="2" Content="×" Tag="{Binding Id}" Click="CloseManagedPin_Click" Width="28" Height="28" Padding="0" Background="#FECACA" ToolTip="Close this pin"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border x:Name="ShortcutPanel" Grid.Row="3" Background="#E7F0F4" BorderBrush="{StaticResource BottomBarBrush}" BorderThickness="1" CornerRadius="14" Padding="18" Margin="0,18,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Capture shortcut" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Text="Choose the key that starts region capture." Foreground="{StaticResource MutedBrush}" Margin="0,3,20,0"/>
                </StackPanel>
                <ComboBox x:Name="CaptureHotkeyCombo" Grid.Column="1" Width="180" Height="38" Margin="10,0"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Name" Background="{StaticResource SecondaryAccentBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BottomBarBrush}" VerticalContentAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Save shortcut" Click="SaveHotkey_Click" Padding="16,9" Margin="0,0,8,0"/>
                    <Button Content="More settings" Click="Preferences_Click" Padding="16,9" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource NeutralBrush}" BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,9,0"/>
                <TextBlock x:Name="StatusText" Text="Global shortcuts are ready" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Alt+Shift+P restores click-through pins" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                <Button Content="History" Click="History_Click" Background="{StaticResource NeutralBrush}" Foreground="{StaticResource TextBrush}" Padding="13,7" Margin="12,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
