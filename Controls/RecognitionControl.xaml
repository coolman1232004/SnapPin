<UserControl x:Class="SnapAnchor.Controls.RecognitionControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Focusable="True" Background="White">
    <UserControl.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34"/><Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="2"/><Setter Property="Padding" Value="7"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#101828"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBackground" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ButtonBackground" Property="Background" Value="#E8F1FF"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ButtonBackground" Property="Background" Value="#D6E7FF"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.35"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="176"/></Grid.RowDefinitions>
        <Border Background="White">
            <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>
        <Border Grid.Row="1" Background="White" BorderBrush="#D0D5DD" BorderThickness="0,1,0,0" Padding="8">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="ScanButton" Style="{StaticResource IconButton}" ToolTip="Recognize text and scan QR/barcodes" Click="Scan_Click">
                            <Path Data="M4,9 V4 H9 M15,4 H20 V9 M20,15 V20 H15 M9,20 H4 V15 M8,8 H16 V16 H8 Z" Stroke="#1677FF" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="CopyButton" Style="{StaticResource IconButton}" ToolTip="Copy results" Click="Copy_Click">
                            <Path Data="M4,7 H17 V21 H4 Z M8,3 H21 V17" Stroke="#101828" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="SearchButton" Style="{StaticResource IconButton}" ToolTip="Search recognized text" Click="Search_Click">
                            <Path Data="M10,4 A6,6 0 1 1 9.9,4 M14.5,14.5 L21,21" Stroke="#101828" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"/>
                        </Button>
                        <Button x:Name="OpenButton" Style="{StaticResource IconButton}" ToolTip="Open recognized web link" Click="Open_Click">
                            <Path Data="M13,4 H21 V12 M21,4 L11,14 M18,13 V21 H4 V7 H12" Stroke="#101828" StrokeThickness="2" Fill="Transparent" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource IconButton}" ToolTip="Close recognition panel" Click="Close_Click">
                            <Path Data="M5,5 L19,19 M19,5 L5,19" Stroke="#667085" StrokeThickness="2.3" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                    <ComboBox x:Name="LanguageBox" Width="190" Height="31" Margin="0,0,8,5" SelectedValuePath="Tag" SelectionChanged="Language_Changed">
                        <ComboBoxItem Content="Japanese" Tag="jpn"/>
                        <ComboBoxItem Content="English + Japanese" Tag="eng+jpn"/>
                        <ComboBoxItem Content="English + Chinese + Japanese" Tag="eng+chi_sim+chi_tra+jpn"/>
                        <ComboBoxItem Content="English" Tag="eng"/>
                        <ComboBoxItem Content="English + 简体中文" Tag="eng+chi_sim"/>
                        <ComboBoxItem Content="English + 繁體中文" Tag="eng+chi_tra"/>
                        <ComboBoxItem Content="English + 简体 + 繁體" Tag="eng+chi_sim+chi_tra"/>
                    </ComboBox>
                </DockPanel>
                <TextBox x:Name="ResultBox" Grid.Row="1" Background="#F6F7F9" Foreground="#101828" BorderBrush="#E4E7EC"
                         BorderThickness="1" Padding="8,6" FontFamily="Segoe UI" FontSize="13" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
                <TextBlock x:Name="StatusText" Grid.Row="2" Foreground="#667085" FontSize="11" Margin="2,5,0,0" Text="Ready"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
